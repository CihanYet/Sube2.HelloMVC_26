@model Ogrenci
@{
    ViewData["Title"] = "OgrenciEkle";
    ViewData["Desc"] = "Öğrenci ekleme sayfası";
}

<h1>Ögrenci Ekle</h1>

<form asp-action="OgrenciEkle" asp-controller="Ogrenci" method="post">
    <div class="mb-3">
        <label asp-for="Ad" class="form-label"></label>
        <input asp-for="Ad" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Soyad" class="form-label"></label>
        <input asp-for="Soyad" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Numara" class="form-label"></label>
        <input asp-for="Numara" class="form-control" />
    </div>
    <input type="submit" name="btnKaydet" value="Kaydet" class="btn btn-primary" />
</form>