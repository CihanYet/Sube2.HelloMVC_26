@model IEnumerable<Ogrenci>

@{
    ViewData["Title"] = "Index";
}

<h1>Öğrenci Listesi</h1>

@* <ul>
    @foreach (var item in Model)
    {
        <li>@item.Ad - @item.Soyad</li>
    }
</ul> *@

<table class="table">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Soyad</th>
            <th>Numara</th>
            <th>İşlemler</th>  
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Ad</td>
                <td>@item.Soyad</td>
                <td>@item.Numara</td>
                <td><a href="" class="btn btn-sm btn-primary">Detay</a></td>
            </tr>
        }
    </tbody>
</table>




